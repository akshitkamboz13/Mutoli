# GOOGLE SERVICES & ORDER DATA
# =============================================================================

# Google Sheets exports (order data)
*.xlsx
*.xls
orders-export-*.csv
customer-data-*.csv

# Apps Script backups
gas-backup/

# =============================================================================
# DEPLOYMENT & HOSTING
# =============================================================================

# Hosting configurations
.netlify/
.vercel/
.firebase/

